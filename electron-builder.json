{
  "appId": "com.postbell.desktop",
  "productName": "Postbell",
  "publish": {
    "provider": "github",
    "owner": "claudeyt",
    "repo": "postbell"
  },
  "directories": {
    "buildResources": "build",
    "output": "dist"
  },
  "files": [
    "main.js",
    "preload.js",
    "migration.js",
    "dist-renderer/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "dist-backend/postbell-backend",
      "to": "backend",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Postbell"
  }
}
