{
  "name": "postbell-electron",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:wait": "wait-on http://localhost:5174 && electron .",
    "dev:renderer": "vite --config vite.electron.config.ts --port 5174",
    "build:renderer": "vite build --config vite.electron.config.ts",
    "dev": "concurrently -k -n VITE,ELECTRON \"npm:dev:renderer\" \"npm run start:wait\"",
    "build:backend": "python scripts/bundle-backend.py",
    "build": "electron-builder",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "electron": "28.3.3",
    "electron-builder": "24.13.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.60.0",
    "electron-updater": "6.8.9",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-router-dom": "^6.28.0"
  }
}
